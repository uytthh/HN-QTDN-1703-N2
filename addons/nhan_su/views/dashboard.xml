<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================== DASHBOARD NHÂN SỰ ===================== -->
    
    <!-- ========== PIVOT VIEWS ========== -->
    
    <!-- Pivot View Nhân viên theo phòng ban và chức vụ -->
    <record id="view_nhan_vien_pivot" model="ir.ui.view">
        <field name="name">nhan_vien.pivot</field>
        <field name="model">nhan_vien</field>
        <field name="arch" type="xml">
            <pivot string="Thống kê nhân viên theo phòng ban" display_quantity="true">
                <field name="phong_ban_id" type="row"/>
                <field name="chuc_vu_id" type="col"/>
            </pivot>
        </field>
    </record>
    
    <!-- Pivot View - Tuổi trung bình theo phòng ban -->
    <record id="view_nhan_vien_pivot_tuoi" model="ir.ui.view">
        <field name="name">nhan_vien.pivot.tuoi</field>
        <field name="model">nhan_vien</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <pivot string="Độ tuổi trung bình" display_quantity="true">
                <field name="phong_ban_id" type="row"/>
                <field name="gioi_tinh" type="col"/>
                <field name="tuoi" type="measure"/>
            </pivot>
        </field>
    </record>
    
    <!-- Pivot View - Theo giới tính -->
    <record id="view_nhan_vien_pivot_gioi_tinh" model="ir.ui.view">
        <field name="name">nhan_vien.pivot.gioi_tinh</field>
        <field name="model">nhan_vien</field>
        <field name="priority">55</field>
        <field name="arch" type="xml">
            <pivot string="Thống kê theo giới tính" display_quantity="true">
                <field name="gioi_tinh" type="row"/>
                <field name="phong_ban_id" type="col"/>
            </pivot>
        </field>
    </record>
    
    <!-- Pivot View - Theo trạng thái -->
    <record id="view_nhan_vien_pivot_trang_thai" model="ir.ui.view">
        <field name="name">nhan_vien.pivot.trang_thai</field>
        <field name="model">nhan_vien</field>
        <field name="priority">60</field>
        <field name="arch" type="xml">
            <pivot string="Thống kê theo trạng thái" display_quantity="true">
                <field name="trang_thai" type="row"/>
                <field name="phong_ban_id" type="col"/>
            </pivot>
        </field>
    </record>
    
    <!-- ========== GRAPH VIEWS ========== -->
    
    <!-- Graph View - Pie: Nhân viên theo phòng ban -->
    <record id="view_nhan_vien_graph" model="ir.ui.view">
        <field name="name">nhan_vien.graph</field>
        <field name="model">nhan_vien</field>
        <field name="arch" type="xml">
            <graph string="Phân bố nhân viên theo phòng ban" type="pie">
                <field name="phong_ban_id" type="row"/>
            </graph>
        </field>
    </record>

    <!-- Graph View - Pie: Giới tính -->
    <record id="view_nhan_vien_graph_gioi_tinh" model="ir.ui.view">
        <field name="name">nhan_vien.graph.gioi_tinh</field>
        <field name="model">nhan_vien</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <graph string="Phân bố giới tính" type="pie">
                <field name="gioi_tinh" type="row"/>
            </graph>
        </field>
    </record>

    <!-- Graph View - Bar: Chức vụ -->
    <record id="view_nhan_vien_graph_chuc_vu" model="ir.ui.view">
        <field name="name">nhan_vien.graph.chuc_vu</field>
        <field name="model">nhan_vien</field>
        <field name="priority">60</field>
        <field name="arch" type="xml">
            <graph string="Số nhân viên theo chức vụ" type="bar">
                <field name="chuc_vu_id" type="row"/>
            </graph>
        </field>
    </record>
    
    <!-- Graph View - Pie: Trạng thái làm việc -->
    <record id="view_nhan_vien_graph_trang_thai" model="ir.ui.view">
        <field name="name">nhan_vien.graph.trang_thai</field>
        <field name="model">nhan_vien</field>
        <field name="priority">65</field>
        <field name="arch" type="xml">
            <graph string="Trạng thái làm việc" type="pie">
                <field name="trang_thai" type="row"/>
            </graph>
        </field>
    </record>
    
    <!-- Graph View - Bar: Tuổi theo phòng ban -->
    <record id="view_nhan_vien_graph_tuoi_pb" model="ir.ui.view">
        <field name="name">nhan_vien.graph.tuoi_pb</field>
        <field name="model">nhan_vien</field>
        <field name="priority">75</field>
        <field name="arch" type="xml">
            <graph string="Độ tuổi trung bình theo phòng ban" type="bar">
                <field name="phong_ban_id" type="row"/>
                <field name="tuoi" type="measure"/>
            </graph>
        </field>
    </record>
    
    <!-- Graph View - Bar: Giới tính theo phòng ban -->
    <record id="view_nhan_vien_graph_gioi_tinh_pb" model="ir.ui.view">
        <field name="name">nhan_vien.graph.gioi_tinh_pb</field>
        <field name="model">nhan_vien</field>
        <field name="priority">80</field>
        <field name="arch" type="xml">
            <graph string="Giới tính theo phòng ban" type="bar" stacked="1">
                <field name="phong_ban_id" type="row"/>
                <field name="gioi_tinh" type="col"/>
            </graph>
        </field>
    </record>
    
    <!-- Graph View - Pie: Quê quán -->
    <record id="view_nhan_vien_graph_que_quan" model="ir.ui.view">
        <field name="name">nhan_vien.graph.que_quan</field>
        <field name="model">nhan_vien</field>
        <field name="priority">85</field>
        <field name="arch" type="xml">
            <graph string="Phân bố theo quê quán" type="pie">
                <field name="que_quan" type="row"/>
            </graph>
        </field>
    </record>
    
    <!-- Graph View - Pie: Tình trạng hôn nhân -->
    <record id="view_nhan_vien_graph_hon_nhan" model="ir.ui.view">
        <field name="name">nhan_vien.graph.hon_nhan</field>
        <field name="model">nhan_vien</field>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <graph string="Tình trạng hôn nhân" type="pie">
                <field name="tinh_trang_hon_nhan" type="row"/>
            </graph>
        </field>
    </record>

    <!-- ========== DASHBOARD ACTIONS ========== -->
    
    <!-- Dashboard chính -->
    <record id="action_nhan_su_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard Nhân sự</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">graph,pivot,kanban,tree,form</field>
        <field name="view_id" ref="view_nhan_vien_graph"/>
        <field name="domain">[('trang_thai', '=', 'dang_lam')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có dữ liệu nhân viên
            </p>
            <p class="text-muted">
                Hãy thêm nhân viên mới để xem thống kê.
            </p>
        </field>
    </record>

    <!-- Thống kê theo phòng ban -->
    <record id="action_thong_ke_phong_ban" model="ir.actions.act_window">
        <field name="name">Thống kê theo phòng ban</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="view_id" ref="view_nhan_vien_pivot"/>
        <field name="domain">[('trang_thai', '=', 'dang_lam')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Phân tích nhân viên theo phòng ban
            </p>
        </field>
    </record>
    
    <!-- Thống kê giới tính -->
    <record id="action_thong_ke_gioi_tinh" model="ir.actions.act_window">
        <field name="name">Thống kê giới tính</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="view_id" ref="view_nhan_vien_graph_gioi_tinh"/>
        <field name="domain">[('trang_thai', '=', 'dang_lam')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Phân tích nhân sự theo giới tính
            </p>
        </field>
    </record>
    
    <!-- Thống kê theo chức vụ -->
    <record id="action_thong_ke_chuc_vu" model="ir.actions.act_window">
        <field name="name">Thống kê theo chức vụ</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="view_id" ref="view_nhan_vien_graph_chuc_vu"/>
        <field name="domain">[('trang_thai', '=', 'dang_lam')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Phân tích nhân sự theo chức vụ
            </p>
        </field>
    </record>
    
    <!-- Thống kê độ tuổi -->
    <record id="action_thong_ke_tuoi" model="ir.actions.act_window">
        <field name="name">Phân tích độ tuổi</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="view_id" ref="view_nhan_vien_pivot_tuoi"/>
        <field name="domain">[('trang_thai', '=', 'dang_lam')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Thống kê độ tuổi nhân viên
            </p>
        </field>
    </record>
    
    <!-- Thống kê quê quán -->
    <record id="action_thong_ke_que_quan" model="ir.actions.act_window">
        <field name="name">Phân bố quê quán</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="view_id" ref="view_nhan_vien_graph_que_quan"/>
        <field name="domain">[('trang_thai', '=', 'dang_lam')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Xem nhân viên theo vùng miền
            </p>
        </field>
    </record>
    
    <!-- Thống kê trạng thái -->
    <record id="action_thong_ke_trang_thai" model="ir.actions.act_window">
        <field name="name">Trạng thái nhân viên</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="view_id" ref="view_nhan_vien_graph_trang_thai"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Phân tích trạng thái làm việc
            </p>
        </field>
    </record>
    
    <!-- Nhân viên đang làm việc -->
    <record id="action_nv_dang_lam" model="ir.actions.act_window">
        <field name="name">NV đang làm việc</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('trang_thai', '=', 'dang_lam')]</field>
    </record>
    
    <!-- Nhân viên đã nghỉ việc -->
    <record id="action_nv_nghi_viec" model="ir.actions.act_window">
        <field name="name">NV đã nghỉ việc</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('trang_thai', '=', 'nghi_viec')]</field>
    </record>
    
    <!-- Nhân viên thử việc -->
    <record id="action_nv_thu_viec" model="ir.actions.act_window">
        <field name="name">NV đang thử việc</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('trang_thai', '=', 'thu_viec')]</field>
    </record>
    
</odoo>
