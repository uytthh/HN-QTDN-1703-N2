<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_chuc_vu_form" model="ir.ui.view">
            <field name="name">chuc_vu</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="ten_chuc_vu" placeholder="Tên chức vụ"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Thông tin chung">
                                <field name="ma_chuc_vu"/>
                                <field name="cap_bac"/>
                            </group>
                            <group string="Thông tin lương">
                                <field name="luong_co_ban_de_xuat"/>
                                <field name="phu_cap_chuc_vu"/>
                            </group>
                        </group>
                        <group string="Mô tả công việc">
                            <field name="mo_ta" nolabel="1" placeholder="Mô tả nhiệm vụ và trách nhiệm của chức vụ..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_chuc_vu_tree" model="ir.ui.view">
            <field name="name">chuc_vu</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                    <field name="cap_bac"/>
                    <field name="luong_co_ban_de_xuat" sum="Tổng"/>
                    <field name="phu_cap_chuc_vu" sum="Tổng"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="chuc_vu_search">
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                </search>
            </field>
        </record>

        <record id="action_chuc_vu" model="ir.actions.act_window">
            <field name="name">Chức vụ</field>
            <field name="res_model">chuc_vu</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref = "chuc_vu_search"/>
        </record>
    </data>
</odoo>
        
    