<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View - Đầy đủ thông tin cho triển khai thực tế -->
        <record id="view_nhan_vien_form" model="ir.ui.view">
            <field name="name">nhan_vien.form</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <form string="Hồ sơ nhân viên">
                    <header>
                        <field name="trang_thai" widget="statusbar" 
                               statusbar_visible="dang_lam,nghi_viec"
                               options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <!-- Placeholder for smart buttons from other modules -->
                        </div>
                        
                        <widget name="web_ribbon" title="ĐANG LÀM VIỆC" bg_color="bg-success" attrs="{'invisible': [('trang_thai', '!=', 'dang_lam')]}"/>
                        <widget name="web_ribbon" title="THỬ VIỆC" bg_color="bg-info" attrs="{'invisible': [('trang_thai', '!=', 'thu_viec')]}"/>
                        <widget name="web_ribbon" title="ĐÃ NGHỈ VIỆC" bg_color="bg-danger" attrs="{'invisible': [('trang_thai', '!=', 'nghi_viec')]}"/>
                        <widget name="web_ribbon" title="TẠM NGHỈ" bg_color="bg-warning" attrs="{'invisible': [('trang_thai', '!=', 'tam_nghi')]}"/>
                        
                        <field name="anh" widget="image" class="oe_avatar" options="{'preview_image': 'anh', 'size': [200, 200]}"/>
                        <div class="oe_title">
                            <label for="ho_va_ten" string="Họ và tên"/>
                            <h1>
                                <field name="ho_va_ten" readonly="1" class="text-primary"/>
                            </h1>
                            <div class="o_row">
                                <span class="badge badge-pill badge-info" style="font-size: 14px;">
                                    <field name="chuc_vu_id" readonly="1" class="oe_inline"/>
                                </span>
                                <span class="text-muted mx-2">|</span>
                                <span class="badge badge-pill badge-secondary" style="font-size: 14px;">
                                    <field name="phong_ban_id" readonly="1" class="oe_inline"/>
                                </span>
                            </div>
                        </div>
                        
                        <group>
                            <group string="Thông tin cơ bản">
                                <field name="ma_dinh_danh" placeholder="NV-0001"/>
                                <field name="ho_ten_dem" placeholder="VD: Nguyễn Văn"/>
                                <field name="ten" placeholder="VD: An"/>
                                <field name="ngay_sinh"/>
                                <field name="tuoi" readonly="1"/>
                                <field name="gioi_tinh" widget="radio" options="{'horizontal': true}"/>
                                <field name="tinh_trang_hon_nhan"/>
                            </group>
                            <group string="Thông tin làm việc">
                                <field name="ngay_vao_lam"/>
                                <field name="ngay_nghi_viec" attrs="{'invisible': [('trang_thai', '!=', 'nghi_viec')]}"/>
                                <field name="email_cong_ty" widget="email" placeholder="an.nguyen@company.com"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Thông tin cá nhân" name="ca_nhan">
                                <group>
                                    <group string="CMND/CCCD">
                                        <field name="so_cmnd" placeholder="012345678901"/>
                                        <field name="ngay_cap_cmnd"/>
                                        <field name="noi_cap_cmnd" placeholder="CA TP. Hồ Chí Minh"/>
                                    </group>
                                    <group string="Địa chỉ">
                                        <field name="que_quan" placeholder="VD: Hà Nội"/>
                                        <field name="dia_chi_hien_tai" placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/TP"/>
                                    </group>
                                </group>
                            </page>
                            
                            <page string="Liên hệ" name="lien_he">
                                <group>
                                    <group string="Thông tin liên hệ">
                                        <field name="email" widget="email"/>
                                        <field name="so_dien_thoai" widget="phone"/>
                                    </group>
                                    <group string="Liên hệ khẩn cấp">
                                        <field name="nguoi_lien_he_khan_cap" placeholder="VD: Nguyễn Văn Bình"/>
                                        <field name="sdt_khan_cap" widget="phone"/>
                                        <field name="quan_he_khan_cap" placeholder="VD: Bố/Mẹ/Vợ/Chồng"/>
                                    </group>
                                </group>
                            </page>
                            
                            <page string="Ngân hàng" name="ngan_hang">
                                <group>
                                    <group string="Thông tin tài khoản ngân hàng">
                                        <field name="ten_ngan_hang" placeholder="VD: Vietcombank"/>
                                        <field name="so_tai_khoan" placeholder="VD: 0123456789"/>
                                        <field name="chi_nhanh_ngan_hang" placeholder="VD: CN Sài Gòn"/>
                                    </group>
                                </group>
                            </page>
                            
                            <page string="Lịch sử công tác" name="lich_su">
                                <field name="lich_su_cong_tac_ids" nolabel="1">
                                    <tree editable="bottom" 
                                          decoration-success="trang_thai == 'Đang giữ'" 
                                          decoration-muted="trang_thai == 'Đã kết thúc'">
                                        <field name="phong_ban_id"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="loai_chuc_vu" widget="badge"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="trang_thai" widget="badge" 
                                               decoration-success="trang_thai == 'Đang giữ'" 
                                               decoration-muted="trang_thai == 'Đã kết thúc'"/>
                                    </tree>
                                </field>
                            </page>
                            
                            <page string="Bằng cấp &amp; Chứng chỉ" name="chung_chi">
                                <field name="danh_sach_chung_chi_bang_cap_ids" nolabel="1">
                                    <tree editable="bottom">
                                        <field name="chung_chi_id"/>
                                        <field name="loai_chung_chi" widget="badge" decoration-info="1"/>
                                        <field name="ngay_cap"/>
                                        <field name="noi_cap"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View - Hiển thị trạng thái nhân viên -->
        <record id="view_nhan_vien_tree" model="ir.ui.view">
            <field name="name">nhan_vien.tree</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <tree string="Danh sách nhân viên" 
                      decoration-success="trang_thai == 'dang_lam'"
                      decoration-info="trang_thai == 'thu_viec'"
                      decoration-muted="trang_thai == 'nghi_viec'"
                      decoration-warning="trang_thai in ['tam_nghi', 'nghi_thai_san']">
                    <field name="ma_dinh_danh" decoration-bf="1"/>
                    <field name="ho_va_ten" decoration-bf="1"/>
                    <field name="gioi_tinh" widget="badge" 
                           decoration-info="gioi_tinh == 'Nam'" 
                           decoration-danger="gioi_tinh == 'Nữ'"/>
                    <field name="tuoi"/>
                    <field name="phong_ban_id" widget="badge" decoration-success="1"/>
                    <field name="chuc_vu_id" widget="badge" decoration-info="1"/>
                    <field name="trang_thai" widget="badge"
                           decoration-success="trang_thai == 'dang_lam'"
                           decoration-info="trang_thai == 'thu_viec'"
                           decoration-muted="trang_thai == 'nghi_viec'"
                           decoration-warning="trang_thai in ['tam_nghi', 'nghi_thai_san']"/>
                    <field name="email" widget="email"/>
                    <field name="so_dien_thoai" widget="phone"/>
                </tree>
            </field>
        </record>

        <!-- Kanban View - Thiết kế đẹp và gọn gàng -->
        <record id="view_nhan_vien_kanban" model="ir.ui.view">
            <field name="name">nhan_vien.kanban</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <kanban default_group_by="phong_ban_id" class="o_kanban_small_column">
                    <field name="id"/>
                    <field name="anh"/>
                    <field name="ho_va_ten"/>
                    <field name="chuc_vu_id"/>
                    <field name="phong_ban_id"/>
                    <field name="email"/>
                    <field name="so_dien_thoai"/>
                    <field name="gioi_tinh"/>
                    <field name="trang_thai"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top" style="padding: 8px;">
                                    <!-- Header với Avatar và Tên -->
                                    <div class="d-flex align-items-center">
                                        <!-- Avatar nhỏ gọn -->
                                        <div t-if="record.anh.raw_value" 
                                             class="rounded-circle mr-2"
                                             style="width: 40px; height: 40px; overflow: hidden; flex-shrink: 0;">
                                            <img t-att-src="kanban_image('nhan_vien', 'anh', record.id.value)" 
                                                 style="width: 100%; height: 100%; object-fit: cover;"/>
                                        </div>
                                        <div t-if="!record.anh.raw_value" 
                                             class="rounded-circle mr-2 d-flex align-items-center justify-content-center"
                                             t-attf-style="width: 40px; height: 40px; flex-shrink: 0; background: #{record.gioi_tinh.raw_value == 'Nam' ? '#3498db' : '#e91e63'}; color: white;">
                                            <i t-attf-class="fa #{record.gioi_tinh.raw_value == 'Nam' ? 'fa-male' : 'fa-female'}" 
                                               style="font-size: 18px;" t-att-title="record.gioi_tinh.value"/>
                                        </div>
                                        
                                        <!-- Tên và Trạng thái -->
                                        <div class="flex-grow-1 min-width-0">
                                            <strong class="d-block text-truncate" style="font-size: 13px;">
                                                <field name="ho_va_ten"/>
                                            </strong>
                                            <span t-attf-class="badge #{record.trang_thai.raw_value == 'dang_lam' ? 'badge-success' : (record.trang_thai.raw_value == 'thu_viec' ? 'badge-info' : 'badge-secondary')}"
                                                  style="font-size: 10px; padding: 2px 6px;">
                                                <field name="trang_thai"/>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Body -->
                                <div class="o_kanban_record_body" style="padding: 0 8px 8px;">
                                    <!-- Chức vụ -->
                                    <div class="mb-1">
                                        <span class="badge" style="background: #2ecc71; color: white; font-size: 10px;">
                                            <field name="chuc_vu_id"/>
                                        </span>
                                    </div>
                                    
                                    <!-- Phòng ban -->
                                    <div class="mb-2">
                                        <span class="badge" style="background: #9b59b6; color: white; font-size: 10px;">
                                            <field name="phong_ban_id"/>
                                        </span>
                                    </div>
                                    
                                    <!-- Thông tin liên hệ -->
                                    <div style="font-size: 11px; color: #7f8c8d;">
                                        <div t-if="record.email.raw_value" class="text-truncate">
                                            <i class="fa fa-envelope-o mr-1" title="Email"/>
                                            <field name="email"/>
                                        </div>
                                        <div t-if="record.so_dien_thoai.raw_value">
                                            <i class="fa fa-phone mr-1" title="Số điện thoại"/>
                                            <field name="so_dien_thoai"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Search View -->
        <record model="ir.ui.view" id="nhan_vien_search">
            <field name="name">nhan_vien.search</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm nhân viên">
                    <field name="ma_dinh_danh" string="Mã NV"/>
                    <field name="ho_va_ten" string="Họ tên"/>
                    <field name="email"/>
                    <field name="so_dien_thoai"/>
                    <field name="phong_ban_id"/>
                    <field name="chuc_vu_id"/>
                    <separator/>
                    <filter string="Đang làm việc" name="dang_lam" domain="[('trang_thai','=','dang_lam')]" icon="fa-check"/>
                    <filter string="Thử việc" name="thu_viec" domain="[('trang_thai','=','thu_viec')]" icon="fa-clock-o"/>
                    <filter string="Đã nghỉ việc" name="nghi_viec" domain="[('trang_thai','=','nghi_viec')]" icon="fa-times"/>
                    <separator/>
                    <filter string="Nam" name="nam" domain="[('gioi_tinh','=','Nam')]" icon="fa-male"/>
                    <filter string="Nữ" name="nu" domain="[('gioi_tinh','=','Nữ')]" icon="fa-female"/>
                    <separator/>
                    <group expand="1" string="Nhóm theo">
                        <filter string="Phòng ban" name="group_phong_ban" context="{'group_by':'phong_ban_id'}"/>
                        <filter string="Chức vụ" name="group_chuc_vu" context="{'group_by':'chuc_vu_id'}"/>
                        <filter string="Trạng thái" name="group_trang_thai" context="{'group_by':'trang_thai'}"/>
                        <filter string="Giới tính" name="group_gioi_tinh" context="{'group_by':'gioi_tinh'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_nhan_vien" model="ir.actions.act_window">
            <field name="name">Nhân viên</field>
            <field name="res_model">nhan_vien</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="nhan_vien_search"/>
            <field name="context">{'search_default_dang_lam': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo nhân viên mới
                </p>
                <p class="text-muted">
                    Quản lý hồ sơ nhân viên đầy đủ bao gồm thông tin cá nhân, 
                    CMND/CCCD, tài khoản ngân hàng, lịch sử công tác và bằng cấp chứng chỉ.
                </p>
            </field>
        </record>
    </data>
</odoo>