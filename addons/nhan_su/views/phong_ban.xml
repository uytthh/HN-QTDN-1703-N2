<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_phong_ban_form" model="ir.ui.view">
            <field name="name">phong_ban.form</field>
            <field name="model">phong_ban</field>
            <field name="arch" type="xml">
                <form string="Phòng ban">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="action" 
                                    name="%(action_nhan_vien)d" icon="fa-users"
                                    context="{'search_default_phong_ban_id': active_id}">
                                <field name="so_nhan_vien_dang_lam" widget="statinfo" string="Nhân viên"/>
                            </button>
                        </div>
                        
                        <widget name="web_ribbon" title="KHÔNG HOẠT ĐỘNG" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                        
                        <div class="oe_title">
                            <label for="ten_phong_ban" string="Tên phòng ban"/>
                            <h1>
                                <field name="ten_phong_ban" placeholder="VD: Phòng Nhân sự"/>
                            </h1>
                        </div>
                        
                        <group>
                            <group string="Thông tin chung">
                                <field name="ma_phong_ban" placeholder="PB-001"/>
                                <field name="parent_id"/>
                                <field name="truong_phong_id"/>
                                <field name="active"/>
                            </group>
                            <group string="Thống kê">
                                <field name="so_nhan_vien" readonly="1"/>
                                <field name="so_nhan_vien_dang_lam" readonly="1"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Mô tả" name="mo_ta">
                                <field name="mo_ta" placeholder="Nhập mô tả về chức năng, nhiệm vụ của phòng ban..." nolabel="1"/>
                            </page>
                            <page string="Danh sách nhân viên" name="nhan_vien">
                                <field name="nhan_vien_ids" readonly="1">
                                    <tree decoration-success="trang_thai == 'dang_lam'" 
                                          decoration-muted="trang_thai == 'nghi_viec'">
                                        <field name="ma_dinh_danh"/>
                                        <field name="ho_va_ten"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="trang_thai" widget="badge"/>
                                        <field name="email"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Phòng ban con" name="child" attrs="{'invisible': [('child_ids', '=', [])]}">
                                <field name="child_ids" readonly="1">
                                    <tree>
                                        <field name="ma_phong_ban"/>
                                        <field name="ten_phong_ban"/>
                                        <field name="so_nhan_vien_dang_lam"/>
                                        <field name="truong_phong_id"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_phong_ban_tree" model="ir.ui.view">
            <field name="name">phong_ban.tree</field>
            <field name="model">phong_ban</field>
            <field name="arch" type="xml">
                <tree string="Danh sách phòng ban" decoration-muted="active == False">
                    <field name="ma_phong_ban" decoration-bf="1"/>
                    <field name="ten_phong_ban" decoration-bf="1"/>
                    <field name="parent_id"/>
                    <field name="truong_phong_id"/>
                    <field name="so_nhan_vien_dang_lam" string="Số NV" sum="Tổng"/>
                    <field name="active" invisible="1"/>
                </tree>
            </field>
        </record>
        
        <!-- Kanban View -->
        <record id="view_phong_ban_kanban" model="ir.ui.view">
            <field name="name">phong_ban.kanban</field>
            <field name="model">phong_ban</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_small_column">
                    <field name="id"/>
                    <field name="ten_phong_ban"/>
                    <field name="truong_phong_id"/>
                    <field name="so_nhan_vien_dang_lam"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top mb-2">
                                        <strong class="o_kanban_record_title">
                                            <field name="ten_phong_ban"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_body">
                                        <div class="text-muted" t-if="record.truong_phong_id.value">
                                            <i class="fa fa-user-circle"/> Trưởng phòng: <field name="truong_phong_id"/>
                                        </div>
                                        <div class="mt-2">
                                            <span class="badge badge-primary">
                                                <i class="fa fa-users"/> <field name="so_nhan_vien_dang_lam"/> nhân viên
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Search View -->
        <record model="ir.ui.view" id="phong_ban_search">
            <field name="name">phong_ban.search</field>
            <field name="model">phong_ban</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm phòng ban">
                    <field name="ma_phong_ban"/>
                    <field name="ten_phong_ban"/>
                    <field name="truong_phong_id"/>
                    <separator/>
                    <filter string="Đang hoạt động" name="active" domain="[('active','=',True)]"/>
                    <filter string="Không hoạt động" name="inactive" domain="[('active','=',False)]"/>
                    <separator/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Phòng ban cha" name="group_parent" context="{'group_by':'parent_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_phong_ban" model="ir.actions.act_window">
            <field name="name">Phòng ban</field>
            <field name="res_model">phong_ban</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="search_view_id" ref="phong_ban_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo phòng ban mới
                </p>
                <p class="text-muted">
                    Quản lý cơ cấu tổ chức phòng ban của công ty.
                </p>
            </field>
        </record>
    </data>
</odoo>