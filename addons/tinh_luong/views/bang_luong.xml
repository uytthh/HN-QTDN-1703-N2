<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View - Cải tiến đẹp và chuyên nghiệp hơn -->
    <record id="view_bang_luong_form" model="ir.ui.view">
        <field name="name">bang_luong.form</field>
        <field name="model">bang_luong</field>
        <field name="arch" type="xml">
            <form string="Bảng lương">
                <header>
                    <button name="action_tao_chi_tiet" string="Tạo chi tiết lương" type="object"
                            class="btn-primary" icon="fa-plus"
                            attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>
                    <button name="action_tinh_luong" string="Tính lương" type="object"
                            class="btn-primary" icon="fa-calculator"
                            attrs="{'invisible': [('trang_thai', 'not in', ['nhap', 'da_tinh'])]}"/>
                    <button name="action_gui_duyet" string="Gửi duyệt" type="object"
                            class="btn-warning" icon="fa-paper-plane"
                            attrs="{'invisible': [('trang_thai', '!=', 'da_tinh')]}"/>
                    <button name="action_duyet" string="Phê duyệt" type="object"
                            class="btn-success" icon="fa-check"
                            attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"/>
                    <button name="action_tra_luong" string="Xác nhận trả lương" type="object"
                            class="btn-success" icon="fa-money"
                            attrs="{'invisible': [('trang_thai', '!=', 'da_duyet')]}"/>
                    <button name="action_huy" string="Hủy bảng lương" type="object"
                            class="btn-danger" icon="fa-times"
                            attrs="{'invisible': [('trang_thai', 'in', ['da_tra', 'huy'])]}"/>
                    <button name="action_reset" string="Đặt lại" type="object"
                            class="btn-secondary" icon="fa-refresh"
                            attrs="{'invisible': [('trang_thai', 'in', ['nhap', 'da_tra'])]}"/>
                    <field name="trang_thai" widget="statusbar" 
                           statusbar_visible="nhap,da_tinh,cho_duyet,da_duyet,da_tra"
                           options="{'clickable': '0'}"/>
                </header>
                <sheet>
                    
                    <widget name="web_ribbon" title="ĐÃ TRẢ LƯƠNG" bg_color="bg-success" attrs="{'invisible': [('trang_thai', '!=', 'da_tra')]}"/>
                    <widget name="web_ribbon" title="CHỜ DUYỆT" bg_color="bg-warning" attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"/>
                    <widget name="web_ribbon" title="ĐÃ HỦY" bg_color="bg-danger" attrs="{'invisible': [('trang_thai', '!=', 'huy')]}"/>
                    
                    <div class="oe_title">
                        <label for="ten_bang_luong" string="Bảng lương"/>
                        <h1>
                            <field name="ten_bang_luong" readonly="1" class="text-primary"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Thông tin kỳ lương">
                            <field name="ma_bang_luong" placeholder="BL-YYYY-MM"/>
                            <label for="thang" string="Kỳ lương"/>
                            <div class="o_row">
                                <field name="thang" class="oe_inline"/>
                                <span class="mx-2">/</span>
                                <field name="nam" class="oe_inline"/>
                            </div>
                            <label for="ngay_bat_dau" string="Thời gian"/>
                            <div class="o_row">
                                <field name="ngay_bat_dau" readonly="1" class="oe_inline"/>
                                <span class="mx-2">→</span>
                                <field name="ngay_ket_thuc" readonly="1" class="oe_inline"/>
                            </div>
                        </group>
                        <group string="Cấu hình &amp; Phê duyệt">
                            <field name="cau_hinh_luong_id" options="{'no_create': True}"/>
                            <field name="nguoi_duyet_id" readonly="1"/>
                            <field name="ngay_duyet" readonly="1"/>
                        </group>
                    </group>
                    
                    <!-- Thống kê tổng quan dạng card -->
                    <div class="row mt-3 mb-3">
                        <div class="col-md-3">
                            <div class="card bg-info text-white text-center">
                                <div class="card-body">
                                    <h5 class="card-title">Tổng thu nhập (Gross)</h5>
                                    <h3><field name="tong_luong_gross" widget="monetary" nolabel="1"/></h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-success text-white text-center">
                                <div class="card-body">
                                    <h5 class="card-title">Thực lĩnh (Net)</h5>
                                    <h3><field name="tong_luong_net" widget="monetary" nolabel="1"/></h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-warning text-center">
                                <div class="card-body">
                                    <h5 class="card-title">Bảo hiểm</h5>
                                    <h3><field name="tong_bao_hiem" widget="monetary" nolabel="1"/></h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <notebook>
                        <page string="Chi tiết lương" name="chi_tiet">
                            <field name="chi_tiet_luong_ids" mode="tree" nolabel="1">
                                <tree string="Chi tiết lương từng nhân viên" 
                                      decoration-success="luong_thuc_nhan > 0"
                                      editable="bottom">
                                    <field name="nhan_vien_id"/>
                                    <field name="phong_ban_id" widget="badge" decoration-info="1"/>
                                    <field name="hop_dong_id"/>
                                    <field name="so_cong_thuc_te"/>
                                    <field name="luong_co_ban" widget="monetary" sum="Tổng"/>
                                    <field name="tong_phu_cap" widget="monetary" sum="Tổng"/>
                                    <field name="tong_thu_nhap" widget="monetary" sum="Tổng" decoration-bf="1"/>
                                    <field name="tong_bao_hiem" widget="monetary" sum="Tổng"/>
                                    <field name="tong_tien_phat" widget="monetary" sum="Tổng"/>
                                    <field name="thue_tncn" widget="monetary" sum="Tổng"/>
                                    <field name="luong_thuc_nhan" widget="monetary" sum="Tổng" decoration-bf="1" class="text-success"/>
                                </tree>
                            </field>
                        </page>
                        
                        <page string="Thống kê chi tiết" name="thong_ke">
                            <group>
                                <group string="Tổng hợp lương">
                                    <field name="tong_nhan_vien" readonly="1"/>
                                    <field name="tong_luong_gross" widget="monetary" readonly="1"/>
                                    <field name="tong_luong_net" widget="monetary" readonly="1" class="text-success"/>
                                    <field name="tong_bao_hiem" widget="monetary" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Ghi chú" name="note">
                            <field name="ghi_chu" placeholder="Nhập ghi chú về bảng lương này..." nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View - Cải tiến -->
    <record id="view_bang_luong_tree" model="ir.ui.view">
        <field name="name">bang_luong.tree</field>
        <field name="model">bang_luong</field>
        <field name="arch" type="xml">
            <tree string="Danh sách bảng lương"
                  decoration-success="trang_thai=='da_tra'"
                  decoration-info="trang_thai=='da_duyet'"
                  decoration-warning="trang_thai=='cho_duyet'"
                  decoration-muted="trang_thai=='huy'">
                <field name="ma_bang_luong" decoration-bf="1"/>
                <field name="ten_bang_luong"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="tong_nhan_vien"/>
                <field name="tong_luong_gross" widget="monetary" sum="Tổng Gross"/>
                <field name="tong_luong_net" widget="monetary" sum="Tổng Net" decoration-bf="1"/>
                <field name="trang_thai" widget="badge"
                       decoration-success="trang_thai == 'da_tra'"
                       decoration-info="trang_thai == 'da_duyet'"
                       decoration-warning="trang_thai == 'cho_duyet'"
                       decoration-muted="trang_thai == 'huy'"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_bang_luong_kanban" model="ir.ui.view">
        <field name="name">bang_luong.kanban</field>
        <field name="model">bang_luong</field>
        <field name="arch" type="xml">
            <kanban default_group_by="trang_thai" class="o_kanban_small_column">
                <field name="id"/>
                <field name="ma_bang_luong"/>
                <field name="ten_bang_luong"/>
                <field name="tong_nhan_vien"/>
                <field name="tong_luong_net"/>
                <field name="trang_thai"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top mb-2">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="ten_bang_luong"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div class="row">
                                        <div class="col-6">
                                            <span class="badge badge-secondary">
                                                <i class="fa fa-users"/> <field name="tong_nhan_vien"/> NV
                                            </span>
                                        </div>
                                        <div class="col-6 text-right">
                                            <span t-attf-class="badge #{record.trang_thai.raw_value == 'da_tra' ? 'badge-success' : (record.trang_thai.raw_value == 'cho_duyet' ? 'badge-warning' : 'badge-info')}">
                                                <field name="trang_thai"/>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="mt-3 text-center">
                                        <h4 class="text-success mb-0">
                                            <field name="tong_luong_net" widget="monetary"/>
                                        </h4>
                                        <small class="text-muted">Tổng thực lĩnh</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bang_luong_search" model="ir.ui.view">
        <field name="name">bang_luong.search</field>
        <field name="model">bang_luong</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm bảng lương">
                <field name="ma_bang_luong"/>
                <field name="ten_bang_luong"/>
                <field name="nam"/>
                <separator/>
                <filter string="Nháp" name="nhap" domain="[('trang_thai','=','nhap')]" icon="fa-pencil"/>
                <filter string="Đã tính" name="da_tinh" domain="[('trang_thai','=','da_tinh')]" icon="fa-calculator"/>
                <filter string="Chờ duyệt" name="cho_duyet" domain="[('trang_thai','=','cho_duyet')]" icon="fa-clock-o"/>
                <filter string="Đã duyệt" name="da_duyet" domain="[('trang_thai','=','da_duyet')]" icon="fa-check"/>
                <filter string="Đã trả" name="da_tra" domain="[('trang_thai','=','da_tra')]" icon="fa-money"/>
                <separator/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Năm" name="group_nam" context="{'group_by':'nam'}"/>
                    <filter string="Tháng" name="group_thang" context="{'group_by':'thang'}"/>
                    <filter string="Trạng thái" name="group_trang_thai" context="{'group_by':'trang_thai'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bang_luong" model="ir.actions.act_window">
        <field name="name">Bảng lương</field>
        <field name="res_model">bang_luong</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo bảng lương mới
            </p>
            <p class="text-muted">
                Quản lý bảng lương hàng tháng. Quy trình xử lý:<br/>
                <strong>Tạo bảng</strong> → <strong>Tạo chi tiết</strong> → <strong>Tính lương</strong> → <strong>Gửi duyệt</strong> → <strong>Phê duyệt</strong> → <strong>Trả lương</strong>
            </p>
        </field>
    </record>
</odoo>
