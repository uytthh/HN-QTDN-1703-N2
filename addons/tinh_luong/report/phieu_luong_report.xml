<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Định nghĩa Report Action cho Phiếu lương -->
    <record id="action_report_phieu_luong" model="ir.actions.report">
        <field name="name">Phiếu lương</field>
        <field name="model">chi_tiet_luong</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tinh_luong.report_phieu_luong</field>
        <field name="report_file">tinh_luong.report_phieu_luong</field>
        <field name="print_report_name">'Phieu_luong_%s_%s_%s' % (object.nhan_vien_id.ho_va_ten, object.thang, object.nam)</field>
        <field name="binding_model_id" ref="model_chi_tiet_luong"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Template Phiếu lương -->
    <template id="report_phieu_luong">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="text-center" style="margin-bottom: 30px;">
                            <h2 style="color: #0066cc; font-weight: bold;">PHIẾU LƯƠNG</h2>
                            <h4>
                                Kỳ lương: Tháng <t t-esc="o.thang"/>/<t t-esc="o.nam"/>
                            </h4>
                        </div>

                        <!-- Thông tin nhân viên -->
                        <div style="margin-bottom: 20px; padding: 15px; background-color: #f5f5f5; border-radius: 5px;">
                            <h5 style="color: #333; border-bottom: 2px solid #0066cc; padding-bottom: 5px;">
                                THÔNG TIN NHÂN VIÊN
                            </h5>
                            <table class="table table-borderless" style="margin-bottom: 0;">
                                <tr>
                                    <td style="width: 25%;"><strong>Mã nhân viên:</strong></td>
                                    <td style="width: 25%;"><t t-esc="o.nhan_vien_id.ma_dinh_danh"/></td>
                                    <td style="width: 25%;"><strong>Họ và tên:</strong></td>
                                    <td style="width: 25%;"><t t-esc="o.nhan_vien_id.ho_va_ten"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Phòng ban:</strong></td>
                                    <td><t t-esc="o.phong_ban_id.ten_phong_ban"/></td>
                                    <td><strong>Chức vụ:</strong></td>
                                    <td><t t-esc="o.chuc_vu_id.ten_chuc_vu"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Mã hợp đồng:</strong></td>
                                    <td><t t-esc="o.hop_dong_id.ma_hop_dong"/></td>
                                    <td><strong>Số người phụ thuộc:</strong></td>
                                    <td><t t-esc="o.so_nguoi_phu_thuoc"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Thông tin chấm công -->
                        <div style="margin-bottom: 20px; padding: 15px; background-color: #e8f4e8; border-radius: 5px;">
                            <h5 style="color: #333; border-bottom: 2px solid #28a745; padding-bottom: 5px;">
                                THÔNG TIN CHẤM CÔNG
                            </h5>
                            <table class="table table-borderless" style="margin-bottom: 0;">
                                <tr>
                                    <td style="width: 30%;"><strong>Số công chuẩn:</strong></td>
                                    <td style="width: 20%;"><t t-esc="o.so_cong_chuan"/> ngày</td>
                                    <td style="width: 30%;"><strong>Số công thực tế:</strong></td>
                                    <td style="width: 20%;"><t t-esc="o.so_cong_thuc_te"/> ngày</td>
                                </tr>
                                <tr>
                                    <td><strong>Số ngày vắng:</strong></td>
                                    <td><t t-esc="o.so_ngay_vang"/> ngày</td>
                                    <td><strong>Vắng có phép:</strong></td>
                                    <td><t t-esc="o.so_ngay_vang_co_phep"/> ngày</td>
                                </tr>
                                <tr>
                                    <td><strong>Tổng phút đi muộn:</strong></td>
                                    <td><t t-esc="o.tong_phut_di_muon"/> phút</td>
                                    <td><strong>Tổng phút về sớm:</strong></td>
                                    <td><t t-esc="o.tong_phut_ve_som"/> phút</td>
                                </tr>
                            </table>
                        </div>

                        <!-- Chi tiết lương -->
                        <div style="display: flex; gap: 20px; margin-bottom: 20px;">
                            <!-- Các khoản thu nhập -->
                            <div style="flex: 1; padding: 15px; background-color: #d4edda; border-radius: 5px;">
                                <h5 style="color: #155724; border-bottom: 2px solid #28a745; padding-bottom: 5px;">
                                    CÁC KHOẢN THU NHẬP
                                </h5>
                                <table class="table table-sm" style="margin-bottom: 0;">
                                    <tr>
                                        <td>Lương cơ bản:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.luong_co_ban)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Lương theo công:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.luong_theo_cong)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Tổng phụ cấp:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.tong_phu_cap)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Thu nhập khác:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.thu_nhap_khac)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr style="font-weight: bold; border-top: 2px solid #155724;">
                                        <td>TỔNG THU NHẬP (GROSS):</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.tong_thu_nhap)"/> VNĐ
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Các khoản khấu trừ -->
                            <div style="flex: 1; padding: 15px; background-color: #f8d7da; border-radius: 5px;">
                                <h5 style="color: #721c24; border-bottom: 2px solid #dc3545; padding-bottom: 5px;">
                                    CÁC KHOẢN KHẤU TRỪ
                                </h5>
                                <table class="table table-sm" style="margin-bottom: 0;">
                                    <tr>
                                        <td>BHXH (8%):</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.tien_bhxh)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>BHYT (1.5%):</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.tien_bhyt)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>BHTN (1%):</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.tien_bhtn)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Tiền phạt đi muộn:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.tien_phat_di_muon)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Tiền phạt về sớm:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.tien_phat_ve_som)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Thuế TNCN:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.thue_tncn)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Khấu trừ khác:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.khau_tru_khac)"/> VNĐ
                                        </td>
                                    </tr>
                                    <tr style="font-weight: bold; border-top: 2px solid #721c24;">
                                        <td>TỔNG KHẤU TRỪ:</td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.0f}'.format(o.tong_khau_tru)"/> VNĐ
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Lương thực nhận -->
                        <div style="padding: 20px; background: linear-gradient(135deg, #0066cc, #004499); border-radius: 10px; text-align: center; color: white;">
                            <h4 style="margin-bottom: 10px;">LƯƠNG THỰC NHẬN (NET)</h4>
                            <h2 style="font-size: 36px; font-weight: bold; margin: 0;">
                                <t t-esc="'{:,.0f}'.format(o.luong_thuc_nhan)"/> VNĐ
                            </h2>
                        </div>

                        <!-- Chi tiết thuế TNCN -->
                        <div style="margin-top: 20px; padding: 15px; background-color: #fff3cd; border-radius: 5px;">
                            <h5 style="color: #856404; border-bottom: 2px solid #ffc107; padding-bottom: 5px;">
                                CHI TIẾT TÍNH THUẾ TNCN
                            </h5>
                            <table class="table table-sm table-borderless" style="margin-bottom: 0;">
                                <tr>
                                    <td style="width: 40%;">Thu nhập chịu thuế:</td>
                                    <td><t t-esc="'{:,.0f}'.format(o.thu_nhap_chiu_thue)"/> VNĐ</td>
                                </tr>
                                <tr>
                                    <td>Giảm trừ gia cảnh:</td>
                                    <td><t t-esc="'{:,.0f}'.format(o.giam_tru_gia_canh)"/> VNĐ</td>
                                </tr>
                                <tr>
                                    <td>Thu nhập tính thuế:</td>
                                    <td><t t-esc="'{:,.0f}'.format(o.thu_nhap_tinh_thue)"/> VNĐ</td>
                                </tr>
                            </table>
                        </div>

                        <!-- Ghi chú -->
                        <t t-if="o.ghi_chu">
                            <div style="margin-top: 20px; padding: 15px; background-color: #f5f5f5; border-radius: 5px;">
                                <h5 style="color: #333;">GHI CHÚ</h5>
                                <p><t t-esc="o.ghi_chu"/></p>
                            </div>
                        </t>

                        <!-- Footer -->
                        <div style="margin-top: 40px;">
                            <div style="display: flex; justify-content: space-between;">
                                <div style="text-align: center; width: 45%;">
                                    <p><strong>Người nhận</strong></p>
                                    <p style="font-style: italic;">(Ký, ghi rõ họ tên)</p>
                                    <br/><br/><br/>
                                    <p>___________________________</p>
                                </div>
                                <div style="text-align: center; width: 45%;">
                                    <p><strong>Kế toán trưởng</strong></p>
                                    <p style="font-style: italic;">(Ký, ghi rõ họ tên)</p>
                                    <br/><br/><br/>
                                    <p>___________________________</p>
                                </div>
                            </div>
                        </div>

                        <!-- Ngày in -->
                        <div style="margin-top: 30px; text-align: right; font-style: italic; color: #666;">
                            <p>Ngày in: <t t-esc="context_today().strftime('%d/%m/%Y')"/></p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Report cho Bảng lương tổng hợp -->
    <record id="action_report_bang_luong_tong_hop" model="ir.actions.report">
        <field name="name">Bảng lương tổng hợp</field>
        <field name="model">bang_luong</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tinh_luong.report_bang_luong_tong_hop</field>
        <field name="report_file">tinh_luong.report_bang_luong_tong_hop</field>
        <field name="print_report_name">'Bang_luong_%s_%s' % (object.thang, object.nam)</field>
        <field name="binding_model_id" ref="model_bang_luong"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Template Bảng lương tổng hợp -->
    <template id="report_bang_luong_tong_hop">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="text-center" style="margin-bottom: 30px;">
                            <h2 style="color: #0066cc; font-weight: bold;">BẢNG LƯƠNG TỔNG HỢP</h2>
                            <h3><t t-esc="o.ten_bang_luong"/></h3>
                            <p>Từ ngày: <t t-esc="o.ngay_bat_dau"/> đến ngày: <t t-esc="o.ngay_ket_thuc"/></p>
                        </div>

                        <!-- Thống kê tổng quan -->
                        <div style="margin-bottom: 20px; display: flex; gap: 10px;">
                            <div style="flex: 1; padding: 15px; background-color: #0066cc; color: white; border-radius: 5px; text-align: center;">
                                <h5>Tổng nhân viên</h5>
                                <h3><t t-esc="o.tong_nhan_vien"/></h3>
                            </div>
                            <div style="flex: 1; padding: 15px; background-color: #28a745; color: white; border-radius: 5px; text-align: center;">
                                <h5>Tổng lương Gross</h5>
                                <h3><t t-esc="'{:,.0f}'.format(o.tong_luong_gross)"/></h3>
                            </div>
                            <div style="flex: 1; padding: 15px; background-color: #dc3545; color: white; border-radius: 5px; text-align: center;">
                                <h5>Tổng bảo hiểm</h5>
                                <h3><t t-esc="'{:,.0f}'.format(o.tong_bao_hiem)"/></h3>
                            </div>
                            <div style="flex: 1; padding: 15px; background-color: #17a2b8; color: white; border-radius: 5px; text-align: center;">
                                <h5>Tổng lương Net</h5>
                                <h3><t t-esc="'{:,.0f}'.format(o.tong_luong_net)"/></h3>
                            </div>
                        </div>

                        <!-- Bảng chi tiết -->
                        <table class="table table-bordered table-sm" style="font-size: 11px;">
                            <thead style="background-color: #0066cc; color: white;">
                                <tr>
                                    <th style="text-align: center;">STT</th>
                                    <th>Họ và tên</th>
                                    <th>Phòng ban</th>
                                    <th style="text-align: center;">Công</th>
                                    <th style="text-align: right;">Lương CB</th>
                                    <th style="text-align: right;">Phụ cấp</th>
                                    <th style="text-align: right;">Tổng TN</th>
                                    <th style="text-align: right;">BH</th>
                                    <th style="text-align: right;">Phạt</th>
                                    <th style="text-align: right;">Thuế</th>
                                    <th style="text-align: right;">Thực nhận</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="stt" t-value="0"/>
                                <t t-foreach="o.chi_tiet_luong_ids" t-as="ct">
                                    <t t-set="stt" t-value="stt + 1"/>
                                    <tr>
                                        <td style="text-align: center;"><t t-esc="stt"/></td>
                                        <td><t t-esc="ct.nhan_vien_id.ho_va_ten"/></td>
                                        <td><t t-esc="ct.phong_ban_id.ten_phong_ban"/></td>
                                        <td style="text-align: center;"><t t-esc="ct.so_cong_thuc_te"/></td>
                                        <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(ct.luong_co_ban)"/></td>
                                        <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(ct.tong_phu_cap)"/></td>
                                        <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(ct.tong_thu_nhap)"/></td>
                                        <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(ct.tong_bao_hiem)"/></td>
                                        <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(ct.tong_tien_phat)"/></td>
                                        <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(ct.thue_tncn)"/></td>
                                        <td style="text-align: right; font-weight: bold;"><t t-esc="'{:,.0f}'.format(ct.luong_thuc_nhan)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot style="background-color: #e9ecef; font-weight: bold;">
                                <tr>
                                    <td colspan="4" style="text-align: center;">TỔNG CỘNG</td>
                                    <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(sum(o.chi_tiet_luong_ids.mapped('luong_co_ban')))"/></td>
                                    <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(sum(o.chi_tiet_luong_ids.mapped('tong_phu_cap')))"/></td>
                                    <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(o.tong_luong_gross)"/></td>
                                    <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(o.tong_bao_hiem)"/></td>
                                    <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(sum(o.chi_tiet_luong_ids.mapped('tong_tien_phat')))"/></td>
                                    <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(sum(o.chi_tiet_luong_ids.mapped('thue_tncn')))"/></td>
                                    <td style="text-align: right;"><t t-esc="'{:,.0f}'.format(o.tong_luong_net)"/></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Chữ ký -->
                        <div style="margin-top: 40px;">
                            <div style="display: flex; justify-content: space-between;">
                                <div style="text-align: center; width: 30%;">
                                    <p><strong>Người lập</strong></p>
                                    <p style="font-style: italic;">(Ký, ghi rõ họ tên)</p>
                                    <br/><br/><br/>
                                    <p>___________________________</p>
                                </div>
                                <div style="text-align: center; width: 30%;">
                                    <p><strong>Kế toán trưởng</strong></p>
                                    <p style="font-style: italic;">(Ký, ghi rõ họ tên)</p>
                                    <br/><br/><br/>
                                    <p>___________________________</p>
                                </div>
                                <div style="text-align: center; width: 30%;">
                                    <p><strong>Giám đốc</strong></p>
                                    <p style="font-style: italic;">(Ký, ghi rõ họ tên)</p>
                                    <br/><br/><br/>
                                    <p>___________________________</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
